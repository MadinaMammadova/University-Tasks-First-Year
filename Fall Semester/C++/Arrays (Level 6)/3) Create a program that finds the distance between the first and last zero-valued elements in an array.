#include <iostream>
using namespace std;
int main() {
 int FirstZeroIndex=-1,LastZeroIndex=-1,n; 
 cout<<"Size of A = ";
 cin>>n; 
 int A[n];
 cout<<endl; 
for(int i=0;i<n;i++) { 
  cout<<"A["<<i<<"]= "; 
  cin>>A[i]; 
} 
 cout<<endl; 
for(int i=0;i<n;i++) { 
  if(A[i]==0 && FirstZeroIndex==-1) { 
    FirstZeroIndex=i; 
} 
if(A[i]==0) {
  LastZeroIndex=i;
} 
}
if(FirstZeroIndex==-1) {
  cout<<"No zeros found in the array";
}
else
  cout<<"Length between the first and the last zero elements = "<<LastZeroIndex-FirstZeroIndex; 
 return 0;  
}
