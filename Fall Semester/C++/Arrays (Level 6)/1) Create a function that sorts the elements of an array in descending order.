#include <iostream>
using namespace std;
void SelectionSort(int Array[],int n) {
 int i;
for (i=0;i<n-1;i++) {
  int MinimumIndex=i;
 for (int j=i+1;j<n;j++){
    if (Array[j]<Array[MinimumIndex]) {
      MinimumIndex=j;
}
}
swap(Array[i],Array[MinimumIndex]);
}
}
int main() {
 cout<<"Insert Array's Size = ";
 int n;
 cin>>n;
 int Array[n];
 cout<<endl;
for(int i=0;i<n;i++) {
   cout<<"Array["<<i<<"]= ";
   cin>>Array[i];
}
 cout<<endl;
 cout<<"Correct Order = ";
for (int i=0;i<n;i++) {
  SelectionSort(Array,n);
    cout<<Array[i]<<" ";
}
return 0;
}
