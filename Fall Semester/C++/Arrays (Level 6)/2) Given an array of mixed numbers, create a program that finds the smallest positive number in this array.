#include <iostream>
using namespace std;
int main() {
 int n;
 cout<<"Size of A = ";
 cin>>n;
 int A[n];
 cout<<endl;
for(int i=0;i<n;i++) {
 cout<<"A["<<i<<"] = ";
 cin>>A[i];
}
 int MinimumPositive=-1; 
for(int i=0;i<n;i++) {
  if(A[i]>0) {
   MinimumPositive=A[i];
    break;
}
}
if(MinimumPositive!=-1) {
  for(int i=0;i<n;i++) {
    if(A[i]>0 && A[i]<MinimumPositive) {
      MinimumPositive=A[i];
}
}
cout<<"The smallest positive number = "<<MinimumPositive<<endl;
} 
else
   cout<<"No positive numbers found in the array."<<endl;
 return 0;
}
