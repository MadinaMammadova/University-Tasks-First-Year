#include <iostream>
using namespace std;
int main() {
int b,c,n,s=0;
 cout<<"Size of A = ";
 cin>>n;
int A[n];
cout<<endl;
for(int i=0;i<n;i++) {
  cout<<"A["<<i<<"]= ";
  cin>>A[i];
}
 cout<<endl;
 cout<<"Number One = ";
 cin>>b;
 cout<<"Number Two = ";
 cin>>c;
for(int i=0;i<n;i++) {
 if(b<A[i] && A[i]<c) {
   s=s+A[i];
}
}
cout<<endl;
cout<<"Sum = "<<s;
 return 0;
}
