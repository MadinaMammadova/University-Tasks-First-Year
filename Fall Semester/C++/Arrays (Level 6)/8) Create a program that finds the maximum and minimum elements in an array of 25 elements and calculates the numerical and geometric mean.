using namespace std;
int main() {
 int n,i,MinimumNumber,MaximumNumber;
 double s,p;
 cout<<"Size of Array = ";
 cin>>n;
 int Array[n];
 cout<<endl;
for(i=0;i<n;i++) {
  cout<<"A["<<i<<"]= ";
  cin>>Array[i];
}
 MinimumNumber=Array[0];
 MaximumNumber=Array[0];
for(i=1;i<n;i++) {
 if(Array[i]<MinimumNumber) {
   MinimumNumber=Array[i];
}
if(Array[i]>MaximumNumber) {
  MaximumNumber=Array[i];
}
}
cout<<endl;
s=(MaximumNumber+MinimumNumber)/2;
p=sqrt(MaximumNumber*MinimumNumber);
  cout<<"Numerical Mean = "<<s<<endl;
  cout<<"Geometric Mean = "<<p;
 return 0;
}
