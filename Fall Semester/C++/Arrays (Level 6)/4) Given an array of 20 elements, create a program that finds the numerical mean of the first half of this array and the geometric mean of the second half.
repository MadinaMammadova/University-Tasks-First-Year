#include <iostream>
#include <cmath>
using namespace std;
int main() {
 int n=20;
 double s=0,p=1;
 cout<<"Size of A = "<<n<<endl;
 int A[n];
 cout<<endl;
for(int i=0;i<n;i++) {
 cout<<"A["<<i<<"] = ";
 cin>>A[i];
}
for(int i=0;i<10;i++) {
   s=s+A[i];
}
 for(int i=10;i<n;i++) {
    p=p*A[i];
}
  cout<<endl;
  cout<<"Numerical Mean = "<<s/10<<endl; 
  cout<<"Geometric Mean = "<<pow(p,10);
 return 0;
}
