#include <iostream>
#include <cmath>
using namespace std;
int main() {
int MaximumofA,MaximumofB,n,m;
 cout<<"Size of A = ";
 cin>>n;
int A[n];
 cout<<"Size of B = ";
 cin>>m;
int B[m];
cout<<endl;
for(int i=0;i<n;i++) {
  cout<<"A["<<i<<"]= ";
  cin>>A[i];
}
 cout<<endl;
for(int i=0;i<m;i++) {
  cout<<"B["<<i<<"]= ";
  cin>>B[i];
}
MaximumofA=A[0];
MaximumofB=B[0];
for(int i=0;i<n;i++) {
  if(A[i]>MaximumofA) {
    MaximumofA=A[i];
 }
}
for(int i=0;i<m;i++) {
  if(B[i]>MaximumofB) {
    MaximumofB=B[i];
}
}
swap(MaximumofB,MaximumofA);
  cout<<endl;
  cout<<"MaximumofA = "<<MaximumofA<<endl;
  cout<<"MaximumofB = "<<MaximumofB;
 return 0;
}
