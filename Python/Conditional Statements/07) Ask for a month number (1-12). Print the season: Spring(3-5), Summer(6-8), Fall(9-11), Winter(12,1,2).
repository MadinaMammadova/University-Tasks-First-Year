print("Season Number = ",end=" ")
seasonnumber=int(input())
print("Current Season =",end=" ")
if 3<=seasonnumber<=5:
    print("Spring")
elif 6<=seasonnumber<=8:
    print("Summer")
elif 9<=seasonnumber<=11:
    print("Autumn")
elif seasonnumber==1 or seasonnumber==2 or seasonnumber==12:
    print("Winter")
