print("Weight = ", end=" ")
weight=float(input())
print("Height = ", end=" ")
height=float(input())
BMI=weight/(height**2)
print("Category =",end=" ")
if BMI<18.5:
    print("Underweight")
elif 18.5<=BMI<=24.9:
    print("Normal Weight")
elif  25<=BMI<=29.9:
    print("Overweight")
else:
    print("Obese")
